[
 {erllama_server, [
   {port,                       8080},
   {ip,                         {0,0,0,0}},
   {num_acceptors,              100},
   {tls,                        undefined},
   {model_aliases, #{
     <<"gpt-4o">>        => <<"llama3-8b-q4">>,
     <<"gpt-4o-mini">>   => <<"llama3-8b-q4">>,
     <<"claude-opus-4-7[1m]">> => <<"local-coder:main">>,
     <<"claude-opus-4-7">> => <<"local-coder:main">>,
     <<"claude-sonnet-4-5">> => <<"local-coder:main">>,
     <<"claude-hiku-4-5">> => <<"local-coder:main">>
   }},
   {pool_exhausted_policy,
       {queue, #{concurrency => 2, depth => 100, timeout_ms => 30000}}},
   {per_model_pool_exhausted_policy, #{}},
   {prefill_timeout_ms,         300000},
   {generation_idle_timeout_ms,  60000},
   {max_total_ms,              1800000},
   %% 256 MiB. Anthropic's documented developer-API cap is 32 MB,
   %% but Claude Code on a Max plan effectively pushes far larger
   %% bodies (long conversation history + MCP tool schemas + repo
   %% CLAUDE.md / AGENTS.md context can comfortably reach a few
   %% hundred MB). 256 MiB lets the daemon stand in for the Max
   %% endpoint without 413 surprises. Lower this if memory pressure
   %% on the cowboy acceptor pool becomes a concern; worst case =
   %% pool_concurrency * this value in live buffers.
   {max_request_body_bytes,    268435456},
   {max_embedding_inputs,       256},
   {model_load_policy,          on_demand},
   {shutdown_timeout_ms,        5000},
   {access_log,                 true},
   {request_id_header,          <<"x-request-id">>},
   {max_messages,               1024},
   {max_tools,                  128},
   %% CORS off by default. Set to a map to enable, e.g.
   %%   #{allow_origins => <<"*">>,
   %%     allow_credentials => false,
   %%     allow_methods => <<"GET, POST, OPTIONS">>,
   %%     allow_headers => <<"authorization, content-type, ...">>,
   %%     max_age => 600}
   {cors,                       off},
   {tracing,                    off},
   %% Cache root for downloaded model blobs and refs. When unset
   %% falls back to $XDG_CACHE_HOME/erllama_server/models, then
   %% to filename:basedir(user_cache, "erllama_server")/models.
   %% {model_cache_dir, "/srv/erllama_server/cache"},
   %% Per-format tool-call registry. Entries shipped with the server
   %% are merged on top of operator-supplied entries; uncomment and
   %% extend to register custom format modules. Each model declares
   %% which family it speaks via `loader.tool_call_format` in its
   %% manifest.
   %% {tool_call_formats, #{
   %%   <<"qwen-xml">> => #{module => erllama_server_tool_format_qwen_xml}
   %% }},
   {auto_pull,                  false},
   %% Models pulled in the background at boot. Each entry is a fetch
   %% spec (`hf://`, `ollama://`, `https://`, `file://`, or a short
   %% Ollama-style name). Failures are logged but non-fatal so the
   %% server still comes up if the network is down. Can also be set
   %% via `ERLLAMA_BOOTSTRAP_MODELS=name1,name2`.
   {bootstrap_models, []}
 ]},
 {erllama, [
   %% erllama settings flow through here
 ]}
].
