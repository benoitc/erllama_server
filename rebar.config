{minimum_otp_vsn, "28.0"}.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% Cowboy 2.13's hex tarball ships a rebar.config with a hex-style
    %% version constraint that rebar3 mis-parses. Pull cowboy from
    %% git to bypass that file.
    {cowboy, {git, "https://github.com/ninenines/cowboy.git", {tag, "2.13.0"}}},
    {instrument, "1.0.0"},
    {hackney, "4.0.0"},
    %% Track erllama main while the streaming/grammar/embed work
    %% stabilises. Switch to {erllama, "~> 0.2"} once a hex release
    %% is cut.
    {erllama, {git, "https://github.com/erllama/erllama.git", {branch, "main"}}}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [erllama_server]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {release, {erllama_server, "0.1.0"}, [
                sasl, erllama_server, erllama, cowboy, instrument, hackney
            ]},
            {mode, prod},
            {sys_config, "config/sys.config"},
            {vm_args, "config/vm.args"},
            {include_erts, true},
            {include_src, false}
        ]}
    ]},
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]},
        {deps, []}
    ]}
]}.

{ct_opts, [{verbose, true}]}.

{xref_checks, [
    undefined_function_calls,
    locals_not_used,
    deprecated_function_calls
]}.

{dialyzer, [
    {warnings, [unmatched_returns, error_handling, no_unknown]},
    {plt_apps, all_deps}
]}.

{project_plugins, [
    {erlfmt, "1.7.0"},
    {rebar3_lint, "4.1.1"}
]}.

{elvis, [
    #{
        dirs => ["src"],
        filter => "*.erl",
        rules => [
            {elvis_style, no_macros, disable},
            {elvis_style, no_common_caveats_call, disable},
            {elvis_style, no_init_lists, disable},
            {elvis_style, param_pattern_matching, disable},
            %% Modules whose state is intentionally minimal (own one
            %% ETS table) or carries a non-record map shape. Same
            %% pattern as erllama_cache_ram in the erllama codebase.
            {elvis_style, state_record_and_type, #{
                ignore => [
                    erllama_server_config,
                    erllama_server_loader,
                    erllama_server_queue,
                    erllama_server_registry,
                    erllama_server_fetch_srv,
                    erllama_server_fetch_worker
                ]
            }},
            {elvis_style, no_spec_with_records, #{
                ignore => [
                    erllama_server_translate,
                    erllama_server_pipeline,
                    erllama_server_grammar
                ]
            }},
            {elvis_style, no_throw, #{
                ignore => [erllama_server_translate, erllama_server_grammar]
            }},
            {elvis_style, no_catch_expressions, #{
                ignore => [
                    erllama_server_metrics,
                    erllama_server_h_models,
                    erllama_server_h_health,
                    erllama_server_listener_mon,
                    erllama_server_app,
                    erllama_server_access_log,
                    erllama_server_fetch_srv,
                    erllama_server_fetch_worker
                ]
            }},
            {elvis_style, no_if_expression, #{
                ignore => [erllama_server_queue]
            }},
            %% The handlers' info/3 dispatches and the metrics
            %% facade's init/0 are naturally long lists of clauses /
            %% setup calls. Same reasoning as erllama_cache_meta_srv
            %% in the erllama codebase.
            {elvis_style, max_function_length, #{
                ignore => [
                    erllama_server_h_chat,
                    erllama_server_h_messages,
                    erllama_server_metrics,
                    erllama_server_sup,
                    erllama_server_translate,
                    erllama_server_queue,
                    erllama_server_loader,
                    erllama_server_config,
                    erllama_server_listener_mon,
                    erllama_server_fetch_worker,
                    erllama_server_fetch_srv,
                    erllama_server_fetch_resolvers,
                    erllama_server_gguf
                ]
            }},
            {elvis_style, max_function_clause_length, #{
                ignore => [
                    erllama_server_sup,
                    erllama_server_metrics,
                    erllama_server_queue,
                    erllama_server_loader,
                    erllama_server_config,
                    erllama_server_h_chat,
                    erllama_server_h_messages,
                    erllama_server_listener_mon,
                    erllama_server_fetch_worker
                ]
            }},
            {elvis_style, dont_repeat_yourself, #{
                ignore => [
                    erllama_server_h_chat,
                    erllama_server_h_messages,
                    erllama_server_h_api
                ]
            }},
            %% gbnf() type is internal and not used in any -spec.
            %% Suppress the export-used-types rule for grammar.
            {elvis_style, export_used_types, #{
                ignore => [erllama_server_grammar]
            }},
            {elvis_style, max_module_length, #{
                ignore => [
                    erllama_server_translate,
                    erllama_server_h_chat,
                    erllama_server_h_messages,
                    erllama_server_fetch_worker,
                    erllama_server_fetch_srv,
                    erllama_server_fetch_resolvers
                ]
            }}
        ],
        ruleset => erl_files_strict
    },
    #{
        dirs => ["."],
        filter => "rebar.config",
        rules => [
            {elvis_project, no_branch_deps, disable}
        ],
        ruleset => rebar_config
    }
]}.

{erlfmt, [
    write,
    {files, [
        "{src,test,include}/**/*.{hrl,erl,app.src,escript}",
        "rebar.config"
    ]}
]}.
