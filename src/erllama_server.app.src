{application, erllama_server, [
    {description, "OpenAI-, Anthropic-, and Ollama-compatible HTTP server on top of erllama"},
    {vsn, "0.1.0"},
    {registered, [erllama_server_sup, erllama_server_config]},
    {mod, {erllama_server_app, []}},
    {applications, [
        kernel,
        stdlib,
        sasl,
        crypto,
        ssl,
        inets,
        cowboy,
        instrument,
        hackney,
        erllama
    ]},
    {env, []},
    {modules, []},
    {licenses, ["MIT"]},
    {links, [
        {"GitHub", "https://github.com/erllama/erllama_server"},
        {"Docs", "https://erllama.github.io/erllama_server/"},
        {"Changelog", "https://github.com/erllama/erllama_server/blob/main/CHANGELOG.md"}
    ]},
    {build_tools, ["rebar3"]},
    {files, [
        "src",
        "include",
        "config",
        "guides",
        "rebar.config",
        "rebar.lock",
        "README.md",
        "CHANGELOG.md",
        "LICENSE",
        "openapi.yaml"
    ]}
]}.
